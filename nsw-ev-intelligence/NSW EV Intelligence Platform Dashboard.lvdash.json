{
  "datasets": [
    {
      "name": "regional_metrics",
      "displayName": "Regional Infrastructure Metrics",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mobility_ai.gold.regional_infrastructure_metrics"
      ],
      "catalog": "mobility_ai",
      "schema": "gold"
    },
    {
      "name": "charger_gaps",
      "displayName": "Infrastructure Gaps Analysis",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mobility_ai.gold.charger_recommendations_gaps"
      ],
      "columns": [
        {
          "displayName": "Critical Gap Count",
          "description": "Count of critical infrastructure gaps",
          "expression": "CASE WHEN `gap_category` = 'Critical' THEN 1 ELSE 0 END"
        }
      ],
      "catalog": "mobility_ai",
      "schema": "gold"
    },
    {
      "name": "charger_nearest",
      "displayName": "Nearest Chargers by Location",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mobility_ai.gold.charger_recommendations_nearest\n",
        "WHERE\n",
        "  rank <= 5"
      ],
      "catalog": "mobility_ai",
      "schema": "gold"
    },
    {
      "name": "charger_smart",
      "displayName": "Smart Charger Recommendations",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mobility_ai.gold.charger_recommendations_smart"
      ],
      "catalog": "mobility_ai",
      "schema": "gold"
    },
    {
      "name": "trip_charging",
      "displayName": "Trip Charging Requirements",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mobility_ai.gold.trip_charging_requirements"
      ],
      "catalog": "mobility_ai",
      "schema": "gold"
    },
    {
      "name": "trip_routes",
      "displayName": "Trip Routes Optimal",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mobility_ai.gold.trip_routes_optimal"
      ],
      "catalog": "mobility_ai",
      "schema": "gold"
    },
    {
      "name": "congestion_location",
      "displayName": "Congestion Forecast Location",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mobility_ai.gold.congestion_forecast_location"
      ],
      "columns": [
        {
          "displayName": "High Risk Count",
          "description": "Count of high or critical risk locations",
          "expression": "CASE WHEN `risk_level` IN ('High', 'Critical') THEN 1 ELSE 0 END"
        }
      ],
      "catalog": "mobility_ai",
      "schema": "gold"
    },
    {
      "name": "congestion_hourly",
      "displayName": "Congestion Forecast Hourly",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mobility_ai.gold.congestion_forecast_hourly"
      ],
      "columns": [
        {
          "displayName": "Peak Hour Count",
          "description": "Count of peak hour records",
          "expression": "CASE WHEN `is_peak_hour` = true THEN 1 ELSE 0 END"
        }
      ],
      "catalog": "mobility_ai",
      "schema": "gold"
    },
    {
      "name": "trip_recommendations",
      "displayName": "Trip Recommendations",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  mobility_ai.gold.trip_recommendations"
      ],
      "catalog": "mobility_ai",
      "schema": "gold"
    }
  ],
